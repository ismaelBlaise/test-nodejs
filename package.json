{
  "name": "document-generation-api",
  "version": "1.0.0",
  "description": "Ultra-optimized API for batch document generation with resilience and monitoring",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "dev:watch": "nodemon --exec ts-node src/index.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "benchmark": "ts-node src/scripts/benchmark.ts",
    "worker": "ts-node src/workers/pdf-generator.ts",
    "db:migrate": "npm run build && node dist/scripts/migrate.js",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f"
  },
  "dependencies": {
    "express": "^4.18.2",
    "bull": "^4.11.4",
    "redis": "^4.6.7",
    "mongoose": "^7.4.0",
    "gridfs-stream": "^1.1.1-fix",
    "pdfkit": "^0.13.0",
    "joi": "^17.10.2",
    "winston": "^3.10.0",
    "pino": "^8.16.1",
    "pino-pretty": "^10.2.0",
    "dotenv": "^16.3.1",
    "uuid": "^9.0.0",
    "axios": "^1.5.0",
    "p-retry": "^5.1.2",
    "opossum": "^8.1.0",
    "prom-client": "^15.0.0",
    "cors": "^2.8.5",
    "helmet": "^7.0.0",
    "compression": "^1.7.4",
    "express-rate-limit": "^7.0.0",
    "swagger-ui-express": "^5.0.0",
    "swagger-jsdoc": "^6.2.8"
  },
  "devDependencies": {
    "@types/node": "^20.5.0",
    "@types/express": "^4.17.18",
    "@types/jest": "^29.5.3",
    "typescript": "^5.1.6",
    "ts-node": "^10.9.1",
    "nodemon": "^3.0.1",
    "jest": "^29.6.4",
    "ts-jest": "^29.1.1",
    "eslint": "^8.48.0",
    "@typescript-eslint/eslint-plugin": "^6.5.0",
    "@typescript-eslint/parser": "^6.5.0",
    "prettier": "^3.0.3",
    "supertest": "^6.3.3",
    "@types/supertest": "^2.0.12",
    "mongodb-memory-server": "^9.1.6"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
